{
  "name": "@handoff/blocks",
  "version": "0.0.17",
  "description": "Handoff WordPress plugin — Gutenberg blocks generated from your Handoff design system.",
  "license": "MIT",
  "author": "Brad Mering <brad@convertiv.com>",
  "main": "build/index.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "wp-scripts build",
    "dev": "wp-scripts start",
    "clean": "rm -rf build",
    "build:compiler": "cd compiler && npm ci && npm run build",
    "compile": "node compiler/dist/compiler.mjs",
    "compile:all": "node compiler/dist/compiler.mjs --all",
    "compile:theme": "node compiler/dist/compiler.mjs --theme",
    "wp-env": "wp-env",
    "wp:start": "wp-env start",
    "wp:stop": "wp-env stop",
    "wp:destroy": "wp-env destroy",
    "wp:clean": "wp-env clean",
    "wp:logs": "wp-env logs",
    "wp:cli": "wp-env run cli",
    "release": "bash scripts/release.sh",
    "release:dry": "bash scripts/release.sh --dry-run"
  },
  "dependencies": {
    "@10up/block-components": "^1.22.1"
  },
  "devDependencies": {
    "@wordpress/env": "^10.0.0",
    "@wordpress/scripts": "^27.0.0",
    "copy-webpack-plugin": "^11.0.0"
  }
}
