node_modules
.env
.DS_Store

# Compiler: track compiler/dist/compiler.mjs (the self-contained bundle) in git
# so installs can run `wp handoff compile` without npm install or build steps.
# Intermediate tsc output is not tracked — only the esbuild bundle matters.
compiler/node_modules
compiler/dist/index.js
compiler/dist/index.unbundled.js
compiler/dist/generators
compiler/dist/validators
compiler/dist/types.*

# Generated blocks (rebuilt from Handoff API via compiler)
blocks/*
!blocks/.gitkeep

# Webpack output (rebuilt from blocks/ via wp-scripts)
# Track build/admin/ so the dashboard ships without npm — block builds are project-specific.
build/*
!build/admin
!build/.gitkeep

# Uploads
uploads/*
!uploads/.gitkeep

# Theme generated assets
theme/assets/css/main.css
theme/assets/js/main.js

# Local config (contains credentials)
handoff-wp.config.json
